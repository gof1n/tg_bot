# Augsburg Liquid — переменные окружения
# Скопируйте как .env и заполните. В репозиторий загружайте только .env.example

USER_BOT_TOKEN=
ADMIN_BOT_TOKEN=
# Один ID или несколько через запятую (оба админа получают доступ к админ-боту и уведомлениям)
ADMIN_CHAT_ID=
# Либо задайте список отдельно (опционально):
# ADMIN_IDS=123456789,987654321
DATABASE_PATH=augsburg_liquid.db
CSV_URL=
